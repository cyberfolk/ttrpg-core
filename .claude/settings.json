{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\grafica-prompt-trigger.ps1\"",
            "statusMessage": "Check trigger grafica (prompt)..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \".claude\\hooks\\requisiti-tripwire.ps1\"",
            "if": "Bash(git commit*)",
            "statusMessage": "Check requisiti funzionali..."
          }
        ]
      }
    ]
  }
}
